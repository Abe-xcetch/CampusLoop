# ==============================================================================
# ENVIRONMENT VARIABLES TEMPLATE - CAMPUSLOOP MONOREPO
# ==============================================================================

# --- DJANGO BACKEND ---
DJANGO_SECRET_KEY=django-insecure-development-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend,web

# --- DATABASE CONFIG (POSTGRESQL) ---
DB_NAME=campusloop
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432
DATABASE_URL=postgres://postgres:postgres@db:5432/campusloop

# --- CACHE & BROKER CONFIG (REDIS/CELERY) ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# --- FIREBASE CREDENTIALS (BACKEND) ---
# JSON format representation or filepath to service account JSON
FIREBASE_CREDENTIALS_PATH=/app/apps/backend/firebase-credentials.json
# Alternative inline configuration for Cloud services:
FIREBASE_PROJECT_ID=strathmore-marketplace
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQ...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@strathmore-marketplace.iam.gserviceaccount.com
FIREBASE_STORAGE_BUCKET=strathmore-marketplace.appspot.com

# --- FRONTEND CLIENT VARIABLES (NEXT.JS) ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyA1...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=strathmore-marketplace.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=strathmore-marketplace
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=strathmore-marketplace.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=1234567890
NEXT_PUBLIC_FIREBASE_APP_ID=1:1234567890:web:abcdef

# --- BUSINESS LOGIC RULES ---
ALLOWED_EMAIL_DOMAIN=strathmore.edu
MIN_RATING_FOR_TRUSTED_SELLER=4.5
COMPLETED_TX_FOR_TRUSTED_SELLER=10
